# Copier en .env puis renseigner les vraies valeurs. Consommé par le backend
# (docker-compose.yml et app/config.py). Voir README.md pour le détail de
# chaque étape (créer le projet Supabase, activer les extensions, etc.)

# --- Supabase Postgres ---
# Dashboard Supabase > Project Settings > Database > Connection string >
# onglet "Session pooler" (PAS "Direct connection" : ce hostname n'a qu'un
# enregistrement DNS IPv6, ce qui échoue depuis Docker/Colima et depuis
# beaucoup d'hébergeurs sans sortie IPv6 — vérifié en pratique sur ce projet.
# Le Session pooler reste une connexion Postgres brute via URL, pas le SDK
# supabase-py, et n'a pas les pièges "prepared statements" du mode Transaction.
# Remplacer postgresql:// par postgresql+asyncpg:// pour SQLAlchemy async, et
# retirer les crochets [ ] autour du mot de passe (ce sont des délimiteurs de
# template Supabase, pas des caractères du mot de passe) en percent-encodant
# les caractères spéciaux qu'il contiendrait (/, ?, @, #...).
DATABASE_URL=postgresql+asyncpg://postgres.[project-ref]:[password-url-encoded]@aws-[x]-[region].pooler.supabase.com:5432/postgres

# --- Supabase Storage (audio brut des dictées) ---
SUPABASE_URL=https://[project-ref].supabase.co
# Dashboard Supabase > Project Settings > API > service_role (secret, jamais côté frontend)
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=voice-captures

# --- Mistral AI (Voxtral transcription, extraction structurée, mistral-embed) ---
# https://console.mistral.ai/api-keys
MISTRAL_API_KEY=
